  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#636870", "fontStyle": "italic" }
    },
    {
      "name": "Doc Comment",
      "scope": ["comment.block.documentation", "comment.line.documentation"],
      "settings": { "foreground": "#555A61", "fontStyle": "italic" }
    },
    {
      "name": "Comment TODO",
      "scope": ["comment.line.todo", "keyword.codetag.notation"],
      "settings": { "foreground": "#4E6600", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#166534" }
    },
    {
      "name": "String Doc / Documentation",
      "scope": ["string.quoted.docstring"],
      "settings": { "foreground": "#166534", "fontStyle": "italic" }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape", "string.escape"],
      "settings": { "foreground": "#566E0C" }
    },
    {
      "name": "String Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#92400E" }
    },
    {
      "name": "String URL / Path",
      "scope": ["string.other.link", "markup.underline.link"],
      "settings": { "foreground": "#1B4FCC", "fontStyle": "italic" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#92400E" }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#92400E", "fontStyle": "italic" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.other"],
      "settings": { "foreground": "#92400E" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.modifier"
      ],
      "settings": { "foreground": "#566E0C" }
    },
    {
      "name": "Keyword Return / Conditional / Loop",
      "scope": [
        "keyword.control.return",
        "keyword.control.yield",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.async",
        "keyword.control.await",
        "keyword.control.trycatch"
      ],
      "settings": { "foreground": "#4E6600", "fontStyle": "bold" }
    },
    {
      "name": "Keyword Import / Export / Module",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#555A61", "fontStyle": "italic" }
    },
    {
      "name": "Keyword Exception / Debug",
      "scope": [
        "keyword.control.exception",
        "keyword.control.try",
        "keyword.control.catch",
        "keyword.control.throw",
        "keyword.control.debug"
      ],
      "settings": { "foreground": "#B91C1C" }
    },
    {
      "name": "Keyword Directive / Preprocessor",
      "scope": [
        "keyword.control.directive",
        "keyword.preprocessor",
        "meta.preprocessor",
        "meta.preprocessor.string",
        "meta.preprocessor.numeric"
      ],
      "settings": { "foreground": "#92400E" }
    },
    {
      "name": "Storage Type",
      "scope": ["storage.type", "keyword.declaration"],
      "settings": { "foreground": "#566E0C" }
    },
    {
      "name": "Function Declaration",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#4E6600", "fontStyle": "bold" }
    },
    {
      "name": "Function Call",
      "scope": ["meta.function-call.generic"],
      "settings": { "foreground": "#4E6600", "fontStyle": "bold" }
    },
    {
      "name": "Function Builtin",
      "scope": ["support.function.builtin", "entity.name.function.builtin"],
      "settings": { "foreground": "#B91C1C" }
    },
    {
      "name": "Function Macro",
      "scope": ["support.function.macro", "entity.name.function.macro"],
      "settings": { "foreground": "#566E0C" }
    },
    {
      "name": "Constructor",
      "scope": ["entity.name.function.constructor", "support.function.constructor"],
      "settings": { "foreground": "#566E0C" }
    },
    {
      "name": "Type / Class / Interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#1B4FCC" }
    },
    {
      "name": "Type Builtin / Primitive",
      "scope": [
        "support.type.builtin",
        "support.type.primitive",
        "keyword.type"
      ],
      "settings": { "foreground": "#1B4FCC", "fontStyle": "italic" }
    },
    {
      "name": "Enum",
      "scope": ["entity.name.enum"],
      "settings": { "foreground": "#1B4FCC", "fontStyle": "bold" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#0D0F11" }
    },
    {
      "name": "Variable Builtin (this, self, super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#B91C1C", "fontStyle": "italic" }
    },
    {
      "name": "Variable Member / Object Property",
      "scope": [
        "variable.other.member",
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": { "foreground": "#1B4FCC" }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#0D0F11" }
    },
    {
      "name": "Property / Field",
      "scope": [
        "support.type.property-name",
        "entity.name.variable.field",
        "variable.other.readwrite.member"
      ],
      "settings": { "foreground": "#555A61" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#555A61" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "meta.bracket"
      ],
      "settings": { "foreground": "#636870" }
    },
    {
      "name": "Punctuation Special",
      "scope": [
        "punctuation.definition.interpolation",
        "punctuation.section.interpolation"
      ],
      "settings": { "foreground": "#555A61" }
    },
    {
      "name": "Module / Namespace",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.type.namespace",
        "support.module"
      ],
      "settings": { "foreground": "#555A61", "fontStyle": "italic" }
    },
    {
      "name": "HTML/JSX Tag",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#1B4FCC" }
    },
    {
      "name": "HTML/JSX Tag Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#555A61", "fontStyle": "italic" }
    },
    {
      "name": "HTML/JSX Tag Delimiter",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "#636870" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.decorator punctuation.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": { "foreground": "#92400E" }
    },
    {
      "name": "Label",
      "scope": ["entity.name.label"],
      "settings": { "foreground": "#1B4FCC" }
    },
    {
      "name": "Diff Added",
      "scope": ["markup.inserted", "diff.inserted"],
      "settings": { "foreground": "#166534" }
    },
    {
      "name": "Diff Removed",
      "scope": ["markup.deleted", "diff.deleted"],
      "settings": { "foreground": "#B91C1C" }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#0D0F11", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold", "punctuation.definition.bold"],
      "settings": { "foreground": "#4E6600", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic", "punctuation.definition.italic"],
      "settings": { "foreground": "#555A61", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Inline Code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#166534" }
    },
    {
      "name": "Markdown Link Text",
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#4E6600", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Link URL",
      "scope": ["markup.underline.link", "meta.link.inline.markdown markup.underline.link"],
      "settings": { "foreground": "#1B4FCC", "fontStyle": "italic" }
    },
    {
      "name": "Markdown List Marker",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list.markdown"
      ],
      "settings": { "foreground": "#166534" }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#555A61" }
    },
    {
      "name": "CSS Value / Unit",
      "scope": ["support.constant.property-value", "constant.other.unit"],
      "settings": { "foreground": "#166534" }
    },
    {
      "name": "CSS Selector",
      "scope": ["entity.other.attribute-name.class", "entity.other.attribute-name.id"],
      "settings": { "foreground": "#4E6600" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#B91C1C" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": { "foreground": "#4E6600", "bold": true },
    "function.builtin": "#B91C1C",
    "method": { "foreground": "#4E6600", "bold": true },
    "method.builtin": "#B91C1C",
    "variable": "#0D0F11",
    "variable.defaultLibrary": "#B91C1C",
    "parameter": "#0D0F11",
    "property": "#555A61",
    "class": "#1B4FCC",
    "interface": { "foreground": "#1B4FCC", "italic": true },
    "type": "#1B4FCC",
    "type.defaultLibrary": { "foreground": "#1B4FCC", "italic": true },
    "enum": { "foreground": "#1B4FCC", "bold": true },
    "enumMember": "#92400E",
    "namespace": { "foreground": "#555A61", "italic": true },
    "string": "#166534",
    "number": "#92400E",
    "keyword": "#566E0C",
    "modifier": "#566E0C",
    "comment": { "foreground": "#636870", "italic": true },
    "decorator": "#92400E",
    "macro": "#566E0C"
  }
}
