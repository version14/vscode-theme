  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6E737A", "fontStyle": "italic" }
    },
    {
      "name": "Doc Comment",
      "scope": ["comment.block.documentation", "comment.line.documentation"],
      "settings": { "foreground": "#9CA0A6", "fontStyle": "italic" }
    },
    {
      "name": "Comment TODO",
      "scope": ["comment.line.todo", "keyword.codetag.notation"],
      "settings": { "foreground": "#D2FF3A", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "String Doc / Documentation",
      "scope": ["string.quoted.docstring"],
      "settings": { "foreground": "#4ADE80", "fontStyle": "italic" }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape", "string.escape"],
      "settings": { "foreground": "#B8E625" }
    },
    {
      "name": "String Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#FFB347" }
    },
    {
      "name": "String URL / Path",
      "scope": ["string.other.link", "markup.underline.link"],
      "settings": { "foreground": "#6FB1FF", "fontStyle": "italic" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#FFB347" }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#FFB347", "fontStyle": "italic" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.other"],
      "settings": { "foreground": "#FFB347" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.modifier"
      ],
      "settings": { "foreground": "#B8E625" }
    },
    {
      "name": "Keyword Return / Conditional / Loop",
      "scope": [
        "keyword.control.return",
        "keyword.control.yield",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.async",
        "keyword.control.await",
        "keyword.control.trycatch"
      ],
      "settings": { "foreground": "#D2FF3A" }
    },
    {
      "name": "Keyword Import / Export / Module",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#9CA0A6", "fontStyle": "italic" }
    },
    {
      "name": "Keyword Exception / Debug",
      "scope": [
        "keyword.control.exception",
        "keyword.control.try",
        "keyword.control.catch",
        "keyword.control.throw",
        "keyword.control.debug"
      ],
      "settings": { "foreground": "#FF5C5C" }
    },
    {
      "name": "Keyword Directive / Preprocessor",
      "scope": [
        "keyword.control.directive",
        "keyword.preprocessor",
        "meta.preprocessor",
        "meta.preprocessor.string",
        "meta.preprocessor.numeric"
      ],
      "settings": { "foreground": "#FFB347" }
    },
    {
      "name": "Storage Type",
      "scope": ["storage.type", "keyword.declaration"],
      "settings": { "foreground": "#B8E625" }
    },
    {
      "name": "Function Declaration",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#D2FF3A" }
    },
    {
      "name": "Function Call",
      "scope": ["meta.function-call.generic"],
      "settings": { "foreground": "#D2FF3A" }
    },
    {
      "name": "Function Builtin",
      "scope": ["support.function.builtin", "entity.name.function.builtin"],
      "settings": { "foreground": "#FF5C5C" }
    },
    {
      "name": "Function Macro",
      "scope": ["support.function.macro", "entity.name.function.macro"],
      "settings": { "foreground": "#B8E625" }
    },
    {
      "name": "Constructor",
      "scope": ["entity.name.function.constructor", "support.function.constructor"],
      "settings": { "foreground": "#B8E625" }
    },
    {
      "name": "Type / Class / Interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#6FB1FF" }
    },
    {
      "name": "Type Builtin / Primitive",
      "scope": [
        "support.type.builtin",
        "support.type.primitive",
        "keyword.type"
      ],
      "settings": { "foreground": "#6FB1FF", "fontStyle": "italic" }
    },
    {
      "name": "Enum",
      "scope": ["entity.name.enum"],
      "settings": { "foreground": "#6FB1FF", "fontStyle": "bold" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#F2F4F6" }
    },
    {
      "name": "Variable Builtin (this, self, super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#FF5C5C", "fontStyle": "italic" }
    },
    {
      "name": "Variable Member / Object Property",
      "scope": [
        "variable.other.member",
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": { "foreground": "#6FB1FF" }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#F2F4F6" }
    },
    {
      "name": "Property / Field",
      "scope": [
        "support.type.property-name",
        "entity.name.variable.field",
        "variable.other.readwrite.member"
      ],
      "settings": { "foreground": "#9CA0A6" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#9CA0A6" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "meta.bracket"
      ],
      "settings": { "foreground": "#6E737A" }
    },
    {
      "name": "Punctuation Special",
      "scope": [
        "punctuation.definition.interpolation",
        "punctuation.section.interpolation"
      ],
      "settings": { "foreground": "#9CA0A6" }
    },
    {
      "name": "Module / Namespace",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.type.namespace",
        "support.module"
      ],
      "settings": { "foreground": "#9CA0A6", "fontStyle": "italic" }
    },
    {
      "name": "HTML/JSX Tag",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#6FB1FF" }
    },
    {
      "name": "HTML/JSX Tag Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#9CA0A6", "fontStyle": "italic" }
    },
    {
      "name": "HTML/JSX Tag Delimiter",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "#6E737A" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.decorator punctuation.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": { "foreground": "#FFB347" }
    },
    {
      "name": "Label",
      "scope": ["entity.name.label"],
      "settings": { "foreground": "#6FB1FF" }
    },
    {
      "name": "Diff Added",
      "scope": ["markup.inserted", "diff.inserted"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "Diff Removed",
      "scope": ["markup.deleted", "diff.deleted"],
      "settings": { "foreground": "#FF5C5C" }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#F2F4F6", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold", "punctuation.definition.bold"],
      "settings": { "foreground": "#D2FF3A", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic", "punctuation.definition.italic"],
      "settings": { "foreground": "#9CA0A6", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Inline Code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "Markdown Link Text",
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#D2FF3A" }
    },
    {
      "name": "Markdown Link URL",
      "scope": ["markup.underline.link", "meta.link.inline.markdown markup.underline.link"],
      "settings": { "foreground": "#6FB1FF", "fontStyle": "italic" }
    },
    {
      "name": "Markdown List Marker",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list.markdown"
      ],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#9CA0A6" }
    },
    {
      "name": "CSS Value / Unit",
      "scope": ["support.constant.property-value", "constant.other.unit"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "CSS Selector",
      "scope": ["entity.other.attribute-name.class", "entity.other.attribute-name.id"],
      "settings": { "foreground": "#D2FF3A" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#FF5C5C" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#D2FF3A",
    "function.builtin": "#FF5C5C",
    "method": "#D2FF3A",
    "method.builtin": "#FF5C5C",
    "variable": "#F2F4F6",
    "variable.defaultLibrary": "#FF5C5C",
    "parameter": "#F2F4F6",
    "property": "#9CA0A6",
    "class": "#6FB1FF",
    "interface": { "foreground": "#6FB1FF", "italic": true },
    "type": "#6FB1FF",
    "type.defaultLibrary": { "foreground": "#6FB1FF", "italic": true },
    "enum": { "foreground": "#6FB1FF", "bold": true },
    "enumMember": "#FFB347",
    "namespace": { "foreground": "#9CA0A6", "italic": true },
    "string": "#4ADE80",
    "number": "#FFB347",
    "keyword": "#B8E625",
    "modifier": "#B8E625",
    "comment": { "foreground": "#6E737A", "italic": true },
    "decorator": "#FFB347",
    "macro": "#B8E625"
  }
}
